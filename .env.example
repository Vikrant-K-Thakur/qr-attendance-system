# MongoDB
# For local development
MONGODB_URI=mongodb://localhost:27017/qr-attendance

# For production (MongoDB Atlas)
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?appName=<appName>

# Gmail (use App Password, not your regular Gmail password)
# To generate: Google Account → Security → 2-Step Verification → App Passwords
EMAIL=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
